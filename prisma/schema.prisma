generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id                Int      @id @default(autoincrement())
  name              String
  company           String?
  country           String?
  email             String
  phone             String?
  commodityInterest String?
  message           String
  role              String   // Buyer or Supplier
  createdAt         DateTime @default(now())
}
